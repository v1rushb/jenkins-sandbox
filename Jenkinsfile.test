pipeline {
    agent {
        label 'dev2'
    }

    environment {
        SUDO_ASKPASS = './ci/askpass.sh'
        JENKINS_SUDO_PASSWORD = credentials('jenkins-dev-sudo-pw-full')
    }

    stages {
        stage('Initialize Scripts') {
            steps {
                sh '''
                    set -e
                    chmod 700 ./ci/askpass.sh
                '''
            }
        }

        stage('Test Docker') {
            steps {
                sh '''
                    set -e

                    sudo -Ak docker info

                    sudo -Ak docker run --rm \
                        public.ecr.aws/aws-cli/aws-cli \
                        --version
                '''
            }
        }
    }

    post {
        always {
            sh 'sudo --remove-timestamp || true'
        }
    }
}
